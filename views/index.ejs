<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=Oi&family=Outfit:wght@100..900&family=Roboto+Mono:ital,wght@0,100..700;1,100..700&display=swap" rel="stylesheet">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Datatype:wght@100..900&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Oi&family=Outfit:wght@100..900&family=Roboto+Mono:ital,wght@0,100..700;1,100..700&display=swap" rel="stylesheet">
<link href="css/fontello.css" rel="stylesheet" type="text/css" />
<script src="https://kit.fontawesome.com/236e28bd84.js" crossorigin="anonymous"></script>
<script src="../app.js" defer></script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <title>APi</title>
</head>
<body>
    <header>
        <div class="logo">
            <i class="fa-solid fa-gamepad"></i><h1 class="title-logo"><%-  data.logo %></h1>
        </div>
        <form class="search">
            <i class="fa-solid fa-magnifying-glass"></i><input type="text" placeholder="Search <%-  games%> games" id="search-input">   
            <!-- onfocus="this.placeholder=''" -->
        </form>
        <div class="options">
           <a href="/login">LOG IN</a>
           <a href="/sign_up">SIGN UP</a>
           <div class="mode-content">
            <i class="fa-solid fa-moon moon" aria-hidden="true"></i>
            <i class="fa-solid fa-sun sun" aria-hidden="true"></i>
            <div class="toggle-sw">
                <span class="sw"></span>
            </div> 
           </div>
        </div>
    </header>
    <main>
        <div class="container">
            <nav>
                <div class="sidebar">
                    <% for(let i=0;i<data.sidebar.length;i++){%>
                    <div class="menu">
                        <a href=""><%-  data.sidebar[i] %></a>
                    </div>
                    <%  }%>
                    <div class="elements">
                        <!-- for each dodac  -->
                        <!-- <div class="sidebar_menu">
                            <span class="title_menu">New Releases</span>
                                <ul class="sidebar_list">
                                    <li class="item">
                                         <a href="">
                                            <i class="fa-solid fa-star"></i>
                                             Last 30days</a>
                                    </li>
                                    <li class="item">
                                         <a href="">
                                            <i class="fa-solid fa-fire"></i>
                                            This week</a>
                                    </li>
                                    <li class="item">
                                        <a href="">
                                            <i class="fa-solid fa-forward-fast"></i>
                                            Next week</a>
                                     </li>
                                    <li class="item">
                                     <a href="">
                                        <i class="31">31</i> 
                                          Release calendar</a>
                                    </li>
                                 </ul>
                      </div> -->
                        <% for(let i=0;i<data.sidebarMenu.length;i++){%>
                        <div class="sidebar_menu">
                            <span class="title_menu"><%-  data.sidebarMenu[i].title %></span>
                                <ul class="sidebar_list">
                                    <% for(let j=0;j<data.sidebarMenu[i].Name.length;j++){%>
                                    <li class="item">
                                         <a href="">
                                            <i class="fa-solid <%-  data.sidebarMenu[i].Icon[j] %>"></i>
                                            <%- data.sidebarMenu[i].Name[j] ==="Popular in YEAR" ? data.sidebarMenu[i].Name[j].replace("YEAR", new Date().getFullYear()) : data.sidebarMenu[i].Name[j] %>
                                        </a>
                                    </li>
                                    <%  }%>
                                 </ul>
                      </div>
                      <%  }%>
                      <div class="sidebar_menu">
                        <span class="title_menu">Top</span>
                            <ul class="sidebar_list">
                                <li class="item">
                                    <a href="">
                                       <i class="fa-solid fa-trophy"></i>
                                         Best of the year</a>
                               </li>
                               <li class="item">
                                <a href="">
                                    <i class="fa-solid fa-chart-simple"></i>
                                    Popular in 2025</a>
                                </li>
                                <li class="item">
                                    <a href="">
                                        <i class="fa-solid fa-crown"></i>
                                        All time top 250</a>
                               </li>
                            </ul>
                      </div>
                      <div class="sidebar_menu">
                        <a href="" class="title_menu">All Games</a>
                        <span class="title_menu">Browse</span>
                        <ul class="sidebar_list">
                            <li class="item">
                                <a href="">
                                   <i class="fa-brands fa-unity"></i>
                                     Platforms</a>
                           </li>
                           <li class="item">
                            <a href="">
                                <i class="fa-solid fa-download"></i>
                                Stores</a>
                            </li>
                            <li class="item">
                                <a href="">
                                    <i class="fa-regular fa-folder-open"></i>
                                    Collections</a>
                           </li>
                           <li class="show-all">
                            <div class="discover">
                                <div class="arrow">
                                    <span></span>
                                    <span></span>
                                </div>
                                <span>Show All</span>
                            </div>
                                
                       </li>
                        </ul>
                      </div>
                      <div class="sidebar_menu">
                        <a href="" class="title_menu">Platforms</a>
                        <ul class="sidebar_list">
                            <li class="item">
                                <a href="">
                                    <i class="fa-brands fa-microsoft"></i>
                                     PC</a>
                           </li>
                           <li class="item">
                            <a href="">
                                <i class="fa-brands fa-playstation"></i>
                                PlayStation</a>
                            </li>
                            <li class="item">
                                <a href="">
                                    <i class="fa-brands fa-xbox"></i>
                                    Xbox</a>
                           </li>
                           <li class="show-all">
                            <div class="discover">
                                <div class="arrow">
                                    <span></span>
                                    <span></span>
                                </div>
                                <span>Show All</span>
                            </div>     
                       </li>
                        </ul>
                      </div>
                      <div class="sidebar_menu">
                        <a href="" class="title_menu">Genres</a>
                        <ul class="sidebar_list">
                            <li class="item">
                                <a href="">
                                    <i class="fa-brands fa-free-code-camp"></i>
                                     Free</a>
                           </li>
                           <li class="item">
                            <a href="">
                                <i class="fa-brands fa-uncharted"></i>
                                Action</a>
                            </li>
                            <li class="item">
                                <a href="">
                                    <i class="fa-solid fa-chess-board"></i>
                                    Strategy</a>
                           </li>
                           <li class="show-all">
                            <div class="discover">
                                <div class="arrow">
                                    <span></span>
                                    <span></span>
                                </div>
                                <span>Show All</span>
                            </div>     
                       </li>
                        </ul>
                      </div>
                    </div>
                </div>
            </nav>
            <div class="content">
                <div class="content_header">
                    <h1 class="head1"><%-  data.title[0] %></h1>
                    <p class="subtitle"><%-  data.subtitle %></p>
                    <div class="games">
                        <div class="controls">
                            <div class="filter">

                            </div>
                            <div class="display">
                                
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</body>
</html>